rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny gate
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global utility primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // USER PURCHASES SCHEMA AND VAL
    function isValidPurchaseDoc(data) {
      return data.keys().hasAll(['userId', 'hasPortalPass', 'unlockedPacks'])
        && data.keys().size() == 3
        && data.userId is string 
        && data.userId.size() <= 128
        && data.hasPortalPass is bool
        && data.unlockedPacks is list
        && (data.unlockedPacks.size() == 0 || (data.unlockedPacks.size() > 0 && data.unlockedPacks[0] is string));
    }

    match /user_purchases/{userId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidPurchaseDoc(request.resource.data)
        && request.resource.data.userId == request.auth.uid;
        
      allow update: if isOwner(userId)
        && isValidPurchaseDoc(request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && (
          // Action: Update portal pass activation
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasPortalPass'])) ||
          // Action: Update unlocked premium packs
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unlockedPacks'])) ||
          // Action: Update both (full portal upgrade)
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasPortalPass', 'unlockedPacks']))
        );
    }

    // TEST ATTEMPTS SCHEMA AND VAL
    function isValidTestAttempt(data) {
      return data.keys().hasAll(['userId', 'testId', 'testTitle', 'score', 'totalQuestions', 'timestamp'])
        && data.keys().size() == 6
        && data.userId is string
        && data.userId.size() <= 128
        && data.testId is string
        && data.testId.size() <= 128
        && data.testTitle is string
        && data.testTitle.size() <= 200
        && data.score is int
        && data.totalQuestions is int
        && data.timestamp is int;
    }

    match /test_attempts/{attemptId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(attemptId)
        && isValidTestAttempt(request.resource.data)
        && request.resource.data.userId == request.auth.uid;
        
      allow update, delete: if false; // Attempts are immutable
    }

    // USER PROFILES SCHEMA AND VAL
    function isValidProfile(data) {
      return data.keys().hasAll(['userId', 'fullName', 'phoneNumber', 'state', 'examPreference', 'notificationsActive'])
        && data.keys().size() == 6
        && data.userId is string
        && data.userId.size() <= 128
        && data.fullName is string
        && data.fullName.size() <= 100
        && data.phoneNumber is string
        && data.phoneNumber.size() <= 20
        && data.state is string
        && data.state.size() <= 50
        && data.examPreference is string
        && data.examPreference.size() <= 100
        && data.notificationsActive is bool;
    }

    match /user_profiles/{userId} {
      allow read: if isOwner(userId);
      
      allow create, update: if isOwner(userId)
        && isValidId(userId)
        && isValidProfile(request.resource.data)
        && request.resource.data.userId == request.auth.uid;
    }

    // CLASSROOM LEADS SCHEMA AND VAL
    function isValidClassroomLead(data) {
      return data.keys().hasAll(['fullName', 'email', 'phoneNumber', 'preferredBatch', 'timestamp'])
        && data.keys().size() == 5
        && data.fullName is string
        && data.fullName.size() <= 100
        && data.email is string
        && data.email.size() <= 100
        && data.phoneNumber is string
        && data.phoneNumber.size() <= 20
        && data.preferredBatch is string
        && data.preferredBatch.size() <= 100
        && data.timestamp is int;
    }

    match /classroom_leads/{leadId} {
      allow create: if isValidId(leadId)
        && isValidClassroomLead(request.resource.data);
      
      allow read, update, delete: if false; // Admin console access only
    }

    // JOB ALERTS SCHEMA AND VAL
    function isValidJobAlert(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'organization', 'postName', 'vacancies', 'salary', 'lastDate', 'qualification', 'link', 'details'])
        && data.id is string
        && data.title is string
        && data.category is string
        && data.organization is string
        && data.postName is string
        && data.vacancies is string
        && data.salary is string
        && data.lastDate is string
        && data.qualification is string
        && data.link is string
        && data.details is string
        && (!data.keys().hasAny(['seoTitle']) || data.seoTitle is string)
        && (!data.keys().hasAny(['seoDescription']) || data.seoDescription is string)
        && (!data.keys().hasAny(['keywords']) || data.keywords is string)
        && (!data.keys().hasAny(['slug']) || data.slug is string)
        && (!data.keys().hasAny(['vacancyTableHtml']) || data.vacancyTableHtml is string)
        && (!data.keys().hasAny(['selectionProcessHtml']) || data.selectionProcessHtml is string);
    }

    match /job_alerts/{jobId} {
      allow read: if true;
      allow create, update: if isValidId(jobId) && isValidJobAlert(request.resource.data);
      allow delete: if true;
    }
    match /settings/{docId} {
      allow read: if true;
      allow create, update: if true; // Admin console access in real app, open for this demo
      allow delete: if false;
    }
  }
}
